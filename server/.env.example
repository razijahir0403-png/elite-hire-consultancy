# Server
PORT=5000
NODE_ENV=development

# MongoDB Atlas (recommended for production)
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority
MONGO_URI_FALLBACK=mongodb://127.0.0.1:27017/elite-hire

# Auth
JWT_SECRET=your_secure_jwt_secret_here
# Token lifetime (must match deployed environment; default 1y)
JWT_EXPIRES_IN=1y

# CORS — comma-separated frontend URLs (Vercel, local dev)
# Example: https://your-app.vercel.app,http://localhost:5173
CLIENT_URL=http://localhost:5173

# Monolith mode: serve React build from this server (optional)
# Set to true only when frontend and backend share one host
SERVE_CLIENT=false

# Uploaded files (optional overrides; defaults to server/uploads and server/uploads/clients)
# UPLOADS_ROOT=uploads
# CLIENT_UPLOADS_DIR=uploads/clients
