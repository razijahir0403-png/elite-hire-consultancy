# Backend API URL (include /api suffix)
# Local development:
VITE_API_BASE_URL=http://localhost:5000/api

# Production (Render backend example):
# VITE_API_BASE_URL=https://your-api.onrender.com/api

# Optional: Vite dev server proxy target (see vite.config.js)
# VITE_DEV_PROXY_TARGET=http://localhost:5000
